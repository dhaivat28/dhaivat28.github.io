r\n\r\n    /* Counter\r\n    ========================================================*/\r\n    $('.counterUp').counterUp({\r\n     delay: 10,\r\n     time: 1000\r\n    });\r\n\r\n\r\n    /* Back Top Link active\r\n    ========================================================*/\r\n      var offset = 200;\r\n      var duration = 500;\r\n      $(window).scroll(function() {\r\n        if ($(this).scrollTop() > offset) {\r\n          $('.back-to-top').fadeIn(400);\r\n        } else {\r\n          $('.back-to-top').fadeOut(400);\r\n        }\r\n      });\r\n\r\n      $('.back-to-top').on('click',function(event) {\r\n        event.preventDefault();\r\n        $('html, body').animate({\r\n          scrollTop: 0\r\n        }, 600);\r\n        return false;\r\n      });\r\n\r\n\r\n\r\n  });      \r\n\r\n}(jQuery));"},"lineCount":null}},"error":null,"hash":"6df4c58adfe0b2d5b346459c70c1e41f","cacheData":{"env":{}}}